{
  "name": "vrchat-udon-mcp",
  "version": "2.0.0",
  "description": "MCP server for VRChat UdonSharp - faithful interface over agent-skills-vrc-udon repository",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vrchat-udon-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "config.json",
    "scripts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MauDevVR/vrchat-udon-mcp.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "update-docs": "tsx scripts/update-docs.ts",
    "build-index": "tsx scripts/build-index.ts",
    "prepare": "npm run build",
    "prestart": "pnpm build"
  },
  "keywords": [
    "mcp",
    "vrchat",
    "udon",
    "udonsharp",
    "model-context-protocol"
  ],
  "author": "MauDevVR",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "minisearch": "^7.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
